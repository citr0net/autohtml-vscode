  "HTML Boilerplate": {
    "prefix": ["html5", "!", "boilerplate", "htmldoc"],
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"en\">",
      "<head>",
      "    <meta charset=\"UTF-8\">",
      "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "    <title>${1:Page Title}</title>",
      "</head>",
      "<body>",
      "    <!-- Visible content goes here -->",
